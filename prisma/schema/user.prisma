model User {
    id           String       @id @default(uuid())
    name         String       @db.VarChar(255)
    email        String       @unique
    password     String
    activeStatus ActiveStatus @default(ACTIVE)
    role         Role         @default(USER)
    profile      Profile?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users")
}

model Login {
    id       String @id @default(uuid())
    name     String
    email    String @unique
    password String
    role     Role   @default(USER)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("login")
}
